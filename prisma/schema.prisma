generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// type: CAMPER | CARAVAN | GARAGE
model Slot {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("CAMPER")
  description   String?
  pricePerDay   Float
  pricePerMonth Float
  accessCode    String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model MaintenanceEntry {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
}

model ServiceRequest {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  type        String   // CLEANING | MAINTENANCE | OTHER
  message     String
  status      String   @default("OPEN") // OPEN | DONE
  createdAt   DateTime @default(now())
}

// bookingType: DAILY | MONTHLY   status: PENDING | PAID | CANCELLED
model Booking {
  id            String   @id @default(cuid())
  slotId        String
  slot          Slot     @relation(fields: [slotId], references: [id])
  guestName     String
  guestEmail    String
  guestAddress  String   @default("")
  startDate     DateTime
  endDate       DateTime
  bookingType   String   @default("DAILY")
  totalPrice    Float
  status        String   @default("PENDING")
  paypalOrderId      String?
  createdAt          DateTime         @default(now())
  maintenanceEntries MaintenanceEntry[]
  serviceRequests    ServiceRequest[]
}
